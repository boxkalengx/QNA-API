generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id
  username   String   @unique
  email      String   @unique
  password   String
  created_at DateTime @default(now())

  threads Thread[]

  @@map("users")
}

model Thread {
  id         String   @id
  user_id    String
  title      String
  body       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("threads")
}